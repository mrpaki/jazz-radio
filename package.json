{
  "name": "jazz-radio",
  "version": "1.0.0",
  "description": "Jazz 24 - 24/7 Online Jazz Radio Station",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c cyan,yellow \"nodemon server/index.js\" \"npm --prefix client run dev\"",
    "start": "NODE_ENV=production node server/index.js",
    "build": "npm --prefix client install && npm --prefix client run build",
    "setup": "node server/setup.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "music-metadata": "^10.3.3",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
